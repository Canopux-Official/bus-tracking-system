{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",                    // or "Node16" – important for Node ESM
    "moduleResolution": "node",          // must match module
    "baseUrl": ".",                          // ← root of project (where tsconfig.json lives)
    "paths": {
      "@/*": ["src/*"]                       // ← this is what enables @/db/...
    },
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    // "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "drizzle", "dist"]
}