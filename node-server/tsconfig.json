{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "bundler",       // replaces deprecated "node"
    "rootDir": "./src",                  // explicitly set to fix layout warning
    "paths": {
      "@/*": ["./src/*"]                 // no need for baseUrl when rootDir is set
    },
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "drizzle", "dist"]
}