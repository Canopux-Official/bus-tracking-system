{
  "compilerOptions": {
    "target": "ES2020",                      // Modern JS version
    "module": "CommonJS",                    // Node.js module system
    "lib": ["ES2020"],                       // Available JS features
    "outDir": "./dist",                       // Compiled JS output
    "rootDir": "./src",                       // Source TS folder
    // "strict": true,                           // Enable all strict type checks
    "esModuleInterop": true,                  // For importing CommonJS modules
    "forceConsistentCasingInFileNames": true,// Helps avoid casing errors
    "skipLibCheck": true,                     // Skip type checking for node_modules
    "resolveJsonModule": true,                // Import JSON files
    "noImplicitAny": true,                    // Avoid implicit `any` types
    "noUnusedLocals": true,                   // Warn about unused variables
    "noUnusedParameters": true,               // Warn about unused parameters
    "moduleResolution": "node",               // Node.js-style module resolution
    "sourceMap": true                         // Generate source maps for debugging
  },
  "include": ["src/**/*"],                    // All TS files in src/
  "exclude": ["node_modules", "dist"]         // Ignore node_modules & dist
}